# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=ocr_user
POSTGRES_PASSWORD=ocr_pass
POSTGRES_DB=ocr_db
DB_HOST=localhost
POSTGRES_PORT=5432

# ── API / Auth ────────────────────────────────────────────────────────────────
